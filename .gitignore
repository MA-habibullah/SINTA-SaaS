# Mengabaikan file konfigurasi database lokal & env
.env

# Mengabaikan konfigurasi database (berisi credential sensitif)
/app/Config/Database.php

# Mengabaikan log sampah internal
*.log

# Mengabaikan folder upload dokumen siswa (SPO, KK, Ijazah) & tenant demi privasi data
# Tetap lacak file .htaccess untuk keamanan direktori web server
/storage/app/public/uploads/**/*
/storage/uploads/**/*
/storage/archive/**/*
/storage/app/rate_limit/
# Kecualikan .gitkeep agar struktur folder penting tetap ter-track
!storage/app/public/uploads/**/.gitkeep
!storage/uploads/**/.gitkeep
!storage/archive/**/.gitkeep
# Mengabaikan folder scratch untuk file debugging lokal
/scratch/
/contoh desain tampilan cetak buku induk/
# Mengabaikan file sistem operasi
.DS_Store
Thumbs.db

# Mengabaikan konfigurasi IDE editor lokal
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj

# package-lock.json tetap di-track untuk mengunci versi dependency
# vendor/ dan composer.lock HARUS di-push untuk shared hosting (tidak ada akses composer)
# node_modules/ di-push sesuai kebutuhan deployment
test_*.php
rename_script.php
database_export.sql
SOP_INSTALLATION.*

# Mengabaikan password deploy lokal
.deploy_pass
node_modules/